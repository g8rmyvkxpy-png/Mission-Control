# BharatIntel API - Development Environment

# App
ENVIRONMENT=development
DEBUG=true

# Database (PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///./bharatintel.db

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth
SECRET_KEY=dev-secret-key-change-in-production-12345678

# Anthropic (leave empty to use fallback summary)
ANTHROPIC_API_KEY=
LLM_SUMMARY_ENABLED=true

# Tavily (web search)
TAVILY_API_KEY=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

# Serper.dev (leave empty to use mock data)
SERPER_API_KEY=

# Indian Kanoon
INDIAN_KANOON_API_KEY=

# Sentry
SENTRY_DSN=
