# BharatIntel API — copy to .env and fill in values

# App
ENVIRONMENT=development
DEBUG=true

# Database
# Docker: postgresql+asyncpg://bharatintel:secret@localhost:5432/bharatintel
DATABASE_URL=postgresql+asyncpg://bharatintel:secret@localhost:5432/bharatintel

# Redis
REDIS_URL=redis://localhost:6379/0

# Auth — generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# Anthropic (Claude Haiku for ai_summary)
ANTHROPIC_API_KEY=sk-ant-...
LLM_SUMMARY_ENABLED=true

# Serper.dev (Indian web search) — free tier at serper.dev
SERPER_API_KEY=your-serper-key

# Indian Kanoon API (court cases) — optional, raises rate limits
INDIAN_KANOON_API_KEY=

# Sentry (error monitoring) — leave blank in dev
SENTRY_DSN=
